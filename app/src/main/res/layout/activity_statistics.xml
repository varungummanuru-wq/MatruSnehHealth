<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F3FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kick Statistics"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#5E35B1"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp" />

        <TextView
            android:id="@+id/txtTotalKicks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Kicks Recorded: 0"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:padding="16dp"
            android:background="#D1C4E9"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/txtLastKick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Last Kick: --"
            android:textSize="20sp"
            android:textColor="#000000"
            android:padding="16dp"
            android:background="#E1BEE7"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/txtKickStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Good"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:padding="16dp"
            android:background="#C5CAE9"
            android:layout_marginBottom="20dp" />

        <ProgressBar
            android:id="@+id/progressKicks"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="20"
            android:progress="0"
            android:layout_marginTop="10dp" />

    </LinearLayout>

</ScrollView>