<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F3FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Baby Kick Counter"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#5E35B1"
            android:layout_marginBottom="30dp"/>

        <!-- Count -->

        <TextView
            android:id="@+id/txtCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="60sp"
            android:textStyle="bold"
            android:textColor="#7E57C2"
            android:layout_marginBottom="20dp"/>

        <!-- Progress Bar -->

        <ProgressBar
            android:id="@+id/progressKicks"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="25dp"
            android:max="20"
            android:progress="0"
            android:layout_marginBottom="20dp"/>

        <!-- Status -->

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start counting baby movements"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#388E3C"
            android:layout_marginBottom="30dp"/>

        <!-- Kick Button -->

        <Button
            android:id="@+id/btnKickCount"
            android:layout_width="260dp"
            android:layout_height="90dp"
            android:text="Baby Moved"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="#7E57C2"/>

        <!-- Reset -->

        <Button
            android:id="@+id/btnReset"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:text="Reset Count"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="#E53935"
            android:layout_marginTop="24dp"/>

        <!-- History -->

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:text="Show History"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="#5E35B1"
            android:layout_marginTop="14dp"/>

    </LinearLayout>

</ScrollView>